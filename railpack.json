{
  "build": {
    "steps": {
      "install-deps": {
        "inputs": [
          {
            "local": "."
          }
        ],
        "commands": [
          "pip install -r requirements.txt"
        ]
      }
    }
  },
  "deploy": {
    "base": {
      "image": "python:3.11-slim"
    },
    "inputs": [
      {
        "step": "install-deps"
      },
      {
        "local": ".",
        "exclude": [
          "railpack.json",
          "README.md",
          ".gitignore"
        ]
      }
    ],
    "startCommand": "python basic.py"
  }
}